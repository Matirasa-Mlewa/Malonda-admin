# Malonda App Admin Panel — Environment Variables
# Rename to .env and fill in your values

# Backend API URL — must point to your live Render backend
VITE_API_URL=https://malonda-back-end.onrender.com/api/v1

# WebSocket URL
VITE_SOCKET_URL=https://malonda-back-end.onrender.com

VITE_APP_NAME=Malonda App Admin
VITE_APP_VERSION=1.0.0
